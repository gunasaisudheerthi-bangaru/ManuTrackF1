{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:5105",
      "environmentVariables": { "ASPNETCORE_ENVIRONMENT": "Development" }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://localhost:7105;http://localhost:5105",
      "environmentVariables": { "ASPNETCORE_ENVIRONMENT": "Development" }
    },
    "Docker": { "commandName": "Docker", "launchBrowser": false, "publishAllPorts": true, "useSSL": false }
  }
}
